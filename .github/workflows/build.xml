# WinFusion Android APK Build Workflow
# This workflow builds the WinFusion Android application APK
# Supports manual trigger for building debug APK

name: Build WinFusion APK

on:
  workflow_dispatch:
    inputs:
      build_type:
        description: 'Build Type'
        required: true
        default: 'debug'
        type: choice
        options:
          - debug
          - release
      clean_build:
        description: 'Perform Clean Build'
        required: false
        default: 'false'
        type: boolean

jobs:
  build:
    name: Build ${{ inputs.build_type }} APK
    runs-on: ubuntu-latest
    
    steps:
      # Checkout the repository
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 1
          lfs: true
      
      # Setup Java JDK 17 (required by AGP 9.1.0 and Gradle 9.3.1)
      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'
          cache: 'gradle'
      
      # Setup Android SDK
      - name: Setup Android SDK
        uses: android-actions/setup-android@v3
        with:
          cmdline-tools-version: '11076700'
      
      # Setup specific SDK components based on project requirements
      - name: Install required Android SDK components
        run: |
          $ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager --install \
            "platforms;android-36" \
            "build-tools;36.0.0" \
            "ndk;29.0.14206865" \
            "cmake;3.22.1"
      
      # Setup Gradle
      - name: Setup Gradle
        uses: gradle/actions/setup-gradle@V4
        with:
          gradle-version: 9.3.1
      
      # Cache Gradle dependencies
      - name: Cache Gradle dependencies
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: ${{ runner.os }}-gradle-${{ hashFiles('**/*.gradle*', '**/gradle-wrapper.properties') }}
          restore-keys: |
            ${{ runner.os }}-gradle-
      
      # Cache Android SDK components
      - name: Cache Android SDK
        uses: actions/cache@v4
        with:
          path: |
            ${{ runner.android_sdk.sdk_root }}/ndk/29.0.14206865
            ${{ runner.android_sdk.sdk_root }}/cmake/3.22.1
            ${{ runner.android_sdk.sdk_root }}/build-tools/36.0.0
            ${{ runner.android_sdk.sdk_root }}/platforms/android-36
          key: ${{ runner.os }}-android-sdk-${{ hashFiles('.github/workflows/android.yml') }}
          restore-keys: |
            ${{ runner.os }}-android-sdk-
      
      # Clean build if requested
      - name: Clean build artifacts
        if: inputs.clean_build == 'true'
        run: |
          cd app && ../gradlew clean
      
      # Build debug APK
      - name: Build ${{ inputs.build_type }} APK
        run: |
          cd app && ../gradlew assemble${{ inputs.build_type == 'release' && 'Release' || 'Debug' }} \
            --no-daemon \
            --stacktrace
        env:
          # Configure Gradle JVM arguments
          ORG_GRADLE_PROJECT_JVM_OPTS: "-Xmx4g -XX:+HeapDumpOnOutOfMemoryError"
          # Disable Gradle configuration cache for compatibility
          GRADLE_CONFIGURATION_CACHE: "false"
      
      # Verify build output exists
      - name: Verify APK output
        id: verify_output
        run: |
          if [ "${{ inputs.build_type }}" = "debug" ]; then
            APK_PATH="app/build/outputs/apk/debug/app-debug.apk"
          else
            APK_PATH="app/build/outputs/apk/release/app-release.apk"
          fi
          
          if [ -f "$APK_PATH" ]; then
            echo "APK exists at: $APK_PATH"
            echo "APK_SIZE=$(du -h $APK_PATH | cut -f1)" >> $GITHUB_OUTPUT
            echo "APK_PATH=$APK_PATH" >> $GITHUB_OUTPUT
          else
            echo "Error: APK not found at $APK_PATH"
            ls -la app/build/outputs/apk/ 2>/dev/null || echo "No APK directory found"
            exit 1
          fi
      
      # Upload APK as artifact
      - name: Upload APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: winfusion-${{ inputs.build_type }}-apk
          path: ${{ steps.verify_output.outputs.APK_PATH }}
          retention-days: 7
          compression-level: 9
      
      # Display APK information
      - name: Display APK info
        run: |
          echo "Build completed successfully!"
          echo "APK Location: ${{ steps.verify_output.outputs.APK_PATH }}"
          echo "APK Size: ${{ steps.verify_output.outputs.APK_SIZE }}"
          echo ""
          echo "To download the APK:"
          echo "1. Go to the Artifacts section of this workflow run"
          echo "2. Download the 'winfusion-${{ inputs.build_type }}-apk' artifact"
